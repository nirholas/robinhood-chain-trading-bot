# ─────────────────────────────────────────────────────────────────────────────
# hood-traders configuration. Copy to `.env` and edit. NOTHING here is required
# to run in paper mode — `docker compose up` and `npm run fleet` both work with
# zero config against live mainnet data.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ──────────────────────────────────────────────────────────────────
# Which Robinhood Chain to observe/trade on. mainnet = 4663, testnet = 46630.
HOOD_NETWORK=mainnet
# Optional paid RPC (Alchemy recommended for live trading). Falls back to the
# public RPC baked into viem's chain def when unset.
# HOOD_RPC_URL=https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── Live trading (OFF by default) ────────────────────────────────────────────
# Paper mode is the default and needs none of the below. To trade REAL funds you
# must set HOOD_TRADERS_LIVE=1 AND provide a funded key. Every safeguard below
# still applies in live mode — they are not optional.
HOOD_TRADERS_LIVE=0
# Wallet private key for live/testnet execution. Env var ONLY — never in code.
# ROBINHOOD_CHAIN_PRIVATE_KEY=0x...

# Affirm you are NOT a US/CA/UK/CH person before any Stock Token ACQUISITION.
# Stock Tokens are tokenized debt securities and may not be sold to US persons.
# Leaving this false blocks the premium-watch strategy from buying Stock Tokens
# (it stays alerts-only). Selling and displaying data are never gated.
HOOD_STOCK_TOKEN_ELIGIBLE=false

# ── Global risk rails (apply to the whole fleet) ─────────────────────────────
# Hard ceiling on notional the entire fleet may spend per UTC day, in USDG.
FLEET_MAX_DAILY_SPEND_USDG=250
# Dashboard + kill-switch HTTP server port.
DASHBOARD_PORT=4670
# Path to a file whose existence trips the global kill switch.
KILL_FILE=./KILL

# ── Per-agent risk rails (defaults; overridable per agent in fleet config) ───
AGENT_MAX_POSITION_USDG=50
AGENT_MAX_DAILY_SPEND_USDG=100
AGENT_MAX_SLIPPAGE_BPS=100
AGENT_COOLDOWN_SECONDS=60
